<%- layout("layouts/boilerplate") %>

<div class="helpcenter-page">
  <div class="container">
    <div class="help-header">
      <h1>Hi, how can we help?</h1>
      <p class="lead">Find answers to your questions and get the support you need</p>
      
      <div class="search-box">
        <input type="text" class="form-control" placeholder="Search for help topics...">
        <button class="btn btn-primary">Search</button>
      </div>
      
      <div class="auth-prompt">
        <p>Log in or sign up for personalized help</p>
        <a href="/login" class="btn btn-primary">Log in or sign up</a>
      </div>
    </div>

    <div class="row">
      <div class="col-md-8">
        <h2>Top articles</h2>
        
        <div class="help-articles">
          <div class="help-article">
            <h3><a href="/cancellation-options">Cancel your home reservation as a guest</a></h3>
            <p class="article-meta">Guest • Reservations</p>
            <p class="article-excerpt">Learn how to cancel your reservation and understand refund policies.</p>
          </div>

          <div class="help-article">
            <h3><a href="#">Change the date or time of your service or experience reservation</a></h3>
            <p class="article-meta">Guest • Reservations</p>
            <p class="article-excerpt">Modify your booking dates or times for services and experiences.</p>
          </div>

          <div class="help-article">
            <h3><a href="#">If your host cancels your home reservation</a></h3>
            <p class="article-meta">Guest • Reservations</p>
            <p class="article-excerpt">What happens when a host cancels and how to get rebooked or refunded.</p>
          </div>

          <div class="help-article">
            <h3><a href="#">Payment methods accepted</a></h3>
            <p class="article-meta">Guest • Payments</p>
            <p class="article-excerpt">Learn about the payment methods we accept and how to add them.</p>
          </div>

          <div class="help-article">
            <h3><a href="#">Add or remove a payment method</a></h3>
            <p class="article-meta">Guest • Payments</p>
            <p class="article-excerpt">Manage your payment methods in your account settings.</p>
          </div>

          <div class="help-article">
            <h3><a href="#">When you'll pay for your reservation</a></h3>
            <p class="article-meta">Guest • Payments</p>
            <p class="article-excerpt">Understand our payment schedule and when charges are applied.</p>
          </div>
        </div>

        <h2 class="mt-5">Explore more</h2>
        
        <div class="help-categories">
          <div class="category-card">
            <h3><a href="/aircover">AirCover for guests</a></h3>
            <p>Top-to-bottom protection for your trip</p>
          </div>

          <div class="category-card">
            <h3><a href="/hosting-resources">Essential resources for new hosts</a></h3>
            <p>Get started with hosting and learn best practices</p>
          </div>

          <div class="category-card">
            <h3><a href="/anti-discrimination">Anti-discrimination</a></h3>
            <p>Our commitment to fighting discrimination</p>
          </div>

          <div class="category-card">
            <h3><a href="/disability-support">Disability support</a></h3>
            <p>Accessibility resources and support</p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="sidebar-card">
          <h3>Need to get in touch?</h3>
          <p>Can't find what you're looking for? Contact our support team.</p>
          <a href="/get-help-with-safety-issue" class="btn btn-outline-primary btn-block">Contact Support</a>
        </div>

        <div class="sidebar-card mt-4">
          <h3>Safety concerns</h3>
          <p>If you have a safety issue, we're here to help 24/7.</p>
          <a href="/get-help-with-safety-issue" class="btn btn-primary btn-block">Get help with safety issue</a>
        </div>

        <div class="sidebar-card mt-4">
          <h3>Neighbourhood concerns</h3>
          <p>Report issues with listings in your neighbourhood.</p>
          <a href="/report-neighbourhood-concern" class="btn btn-outline-primary btn-block">Report neighbourhood concern</a>
        </div>
      </div>
    </div>
  </div>
</div>
