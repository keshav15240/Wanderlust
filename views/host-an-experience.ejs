<%- layout("layouts/boilerplate") %>

<div class="host-experience-page">
  <div class="container">
    <div class="hero-section">
      <h1>Get paid to do what you love</h1>
      <p class="lead">Bring the best of your city to life on Wanderlust</p>
      <div class="cta-buttons">
        <a href="#" class="btn btn-primary btn-lg">Get started</a>
      </div>
    </div>

    <div class="row">
      <div class="col-md-8">
        <h2>Host one-of-a-kind experiences of all kinds</h2>
        
        <div class="experience-types">
          <div class="experience-type">
            <h3><i class="fas fa-city"></i> Show off your city</h3>
            <p>Share hidden gems, local culture, and unique perspectives of your hometown.</p>
          </div>
          <div class="experience-type">
            <h3><i class="fas fa-utensils"></i> Share something tasty</h3>
            <p>Host cooking classes, food tours, or dining experiences in your home.</p>
          </div>
          <div class="experience-type">
            <h3><i class="fas fa-hiking"></i> Lead an outdoor adventure</h3>
            <p>Guide guests through hiking, biking, surfing, or other outdoor activities.</p>
          </div>
          <div class="experience-type">
            <h3><i class="fas fa-palette"></i> Celebrate the arts</h3>
            <p>Share your artistic skills through workshops, tours, or creative sessions.</p>
          </div>
          <div class="experience-type">
            <h3><i class="fas fa-heart"></i> Teach fitness and self-care</h3>
            <p>Offer yoga, meditation, wellness, or fitness experiences to guests.</p>
          </div>
        </div>

        <h2>Millions of guests. The most loved brand in travel.</h2>
        <p>Join a community of passionate hosts sharing their skills and stories with travelers from around the world.</p>

        <h2>Show up beautifully. Get booked instantly.</h2>
        <p>Create a compelling experience listing with photos, descriptions, and details that attract guests.</p>

        <h2>Get discovered in all the right places</h2>
        <div class="discovery-features">
          <div class="feature-item">
            <h3>Show up when guests plan</h3>
            <p>Your experience appears when guests search for activities in your area.</p>
          </div>
          <div class="feature-item">
            <h3>Get suggested as guests travel</h3>
            <p>We recommend your experience to guests based on their interests and location.</p>
          </div>
        </div>

        <h2>The best experiences deserve the best tools</h2>
        <div class="tools-features">
          <div class="tool-item">
            <h3>Manage reservations</h3>
            <p>Easily track bookings, communicate with guests, and manage your calendar.</p>
          </div>
          <div class="tool-item">
            <h3>Simplify scheduling</h3>
            <p>Set your availability and let guests book times that work for you.</p>
          </div>
          <div class="tool-item">
            <h3>Connect with guests</h3>
            <p>Message guests before, during, and after their experience.</p>
          </div>
          <div class="tool-item">
            <h3>Get paid quickly</h3>
            <p>Receive payments securely and on time after each experience.</p>
          </div>
        </div>

        <h2>Your questions, answered</h2>
        <div class="faq-section">
          <div class="faq-item">
            <h3>Learn more about Wanderlust Experience standards</h3>
            <p>Understand our quality standards and requirements for experience hosts.</p>
            <a href="#" class="btn-link">Learn more →</a>
          </div>
          <div class="faq-item">
            <h3>Learn more about licensing requirements</h3>
            <p>Find out if you need any licenses or permits to host experiences in your area.</p>
            <a href="#" class="btn-link">Learn about licensing →</a>
          </div>
          <div class="faq-item">
            <h3>Learn more about liability insurance</h3>
            <p>Understand the insurance coverage available for experience hosts.</p>
            <a href="#" class="btn-link">Learn about insurance →</a>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="sidebar-card">
          <h3>Ready to start?</h3>
          <p>Create your experience listing in minutes.</p>
          <a href="#" class="btn btn-primary btn-block">Get started</a>
        </div>

        <div class="sidebar-card mt-4">
          <h3>Hosting resources</h3>
          <ul class="sidebar-links">
            <li><a href="/hosting-resources">Resource Center</a></li>
            <li><a href="/community-forum">Community forum</a></li>
            <li><a href="/hosting-responsibly">Hosting responsibly</a></li>
          </ul>
        </div>

        <div class="sidebar-card mt-4">
          <h3>Success stories</h3>
          <p>Read about hosts who turned their passions into successful experiences.</p>
          <a href="#" class="btn btn-outline-primary btn-block">Read stories</a>
        </div>
      </div>
    </div>
  </div>
</div>
