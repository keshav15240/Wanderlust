<div class="modal fade" id="reviewsModal" tabindex="-1">

    <div class="modal-dialog modal-xl modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header">

                <h3 class="modal-title">

                    ⭐ <%= listing.reviews.length %> Reviews

                </h3>

                <button
                    class="btn-close"
                    data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="row">

                    <% listing.reviews.forEach(review => { %>

                    <div class="col-lg-6 mb-4">

                        <div class="review-card h-100">

                            <!-- Header -->

                            <div class="review-header">

                                <div class="review-avatar">

                                    <%= review.author ? review.author.username.charAt(0).toUpperCase() : "?" %>

                                </div>

                                <div class="review-user-info">

                                    <h5 class="mb-1">

                                        <%= review.author ? review.author.username : "Unknown User" %>

                                    </h5>

                                    <small class="verified-user">

                                        <i class="fa-solid fa-circle-check"></i>

                                        Verified Guest

                                    </small>

                                </div>

                            </div>

                            <!-- Stars -->

                            <div class="review-stars mt-3">

                                <% for(let i=0;i<review.rating;i++){ %>

                                    ★

                                <% } %>

                                <% for(let i=review.rating;i<5;i++){ %>

                                    ☆

                                <% } %>

                                <span class="review-date">

                                    ·

                                    <%= review.createdAt.toLocaleDateString("en-IN",{
                                        month:"short",
                                        year:"numeric"
                                    }) %>

                                </span>

                            </div>

                            <!-- Comment -->

                            <p class="review-comment mt-3">

                                <%= review.comment %>

                            </p>

                            <% if(currentUser && review.author && review.author._id.equals(currentUser._id)){ %>

                                <form
                                    method="POST"
                                    action="/listing/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                                    <button class="btn btn-outline-danger btn-sm mt-3">

                                        Delete Review

                                    </button>

                                </form>

                            <% } %>

                        </div>

                    </div>

                    <% }) %>

                </div>

            </div>

        </div>

    </div>

</div>