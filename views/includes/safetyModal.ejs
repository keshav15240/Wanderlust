
<!-- =====================================
        Safety & Property Modal
====================================== -->

<div class="modal fade"
     id="safetyModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header border-0">

                <h2 class="modal-title">

                    Safety & Property

                </h2>

                <button
                    class="btn-close"
                    data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p class="text-muted mb-5">

                    Please review the safety information before your stay.

                </p>

                <h5 class="mb-4">

                    Safety Devices

                </h5>

                <!-- Camera -->

                <div class="rule">

                    <i class="fa-solid fa-video"></i>

                    <div>

                        <strong>

                            Exterior Security Cameras

                        </strong>

                        <p>

                            CCTV cameras monitor common areas
                            and the entrance for guest safety.

                        </p>

                    </div>

                </div>

                <!-- Carbon -->

                <div class="rule">

                    <i class="fa-solid fa-triangle-exclamation"></i>

                    <div>

                        <strong>

                            Carbon Monoxide Detector

                        </strong>

                        <p>

                            A carbon monoxide detector
                            is installed inside the property.

                        </p>

                    </div>

                </div>

                <!-- Smoke -->

                <div class="rule">

                    <i class="fa-solid fa-fire-extinguisher"></i>

                    <div>

                        <strong>

                            Smoke Alarm

                        </strong>

                        <p>

                            Smoke alarms are installed
                            on every floor.

                        </p>

                    </div>

                </div>

                <!-- First Aid -->

                <div class="rule">

                    <i class="fa-solid fa-kit-medical"></i>

                    <div>

                        <strong>

                            First Aid Kit

                        </strong>

                        <p>

                            A first aid kit is available
                            in the kitchen cabinet.

                        </p>

                    </div>

                </div>

                <!-- Fire -->

                <div class="rule">

                    <i class="fa-solid fa-fire"></i>

                    <div>

                        <strong>

                            Fire Extinguisher

                        </strong>

                        <p>

                            Fire extinguisher available
                            near the kitchen entrance.

                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>